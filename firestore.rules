rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && (request.auth.token is map)
        && ("admin" in request.auth.token)
        && request.auth.token.admin == true;
    }

    function bookingParticipant() {
      return isSignedIn()
        && (
          request.auth.uid == resource.data.learnerId
          || request.auth.uid == resource.data.teacherId
        );
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function teacherDoc(uid) {
      return get(/databases/$(database)/documents/teachers/$(uid));
    }

    function canTeach(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && ("teachingModeEnabled" in userDoc(uid).data)
        && (userDoc(uid).data.teachingModeEnabled == true);
    }

    function groupLessonDoc(lessonId) {
      return get(/databases/$(database)/documents/group_lessons/$(lessonId));
    }

    function groupLessonExists(lessonId) {
      return exists(/databases/$(database)/documents/group_lessons/$(lessonId));
    }

    function isGroupLessonTeacher(lessonId) {
      return groupLessonExists(lessonId)
        && groupLessonDoc(lessonId).data.teacherId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow create: if (
          isOwner(teacherId)
          && canTeach(request.auth.uid)
          && request.resource.data.uid == request.auth.uid
        ) || isAdmin();
      allow update, delete: if (
          isOwner(teacherId)
          && canTeach(request.auth.uid)
        ) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if bookingParticipant() || isAdmin();

      allow create: if (
          isSignedIn()
        && request.resource.data.slotId is string
        && request.resource.data.slotId == bookingId
        && request.resource.data.learnerId == request.auth.uid
        && request.resource.data.teacherId is string
        && request.resource.data.teacherDocId is string
        && exists(/databases/$(database)/documents/teachers/$(request.resource.data.teacherDocId))
        && get(/databases/$(database)/documents/teachers/$(request.resource.data.teacherDocId)).data.uid == request.resource.data.teacherId
        && canTeach(request.resource.data.teacherId)
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        ) || isAdmin();

      allow update: if (
          isSignedIn()
        && request.resource.data.learnerId == resource.data.learnerId
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt", "noShowActor", "cancelledBy", "cancellationReason"])
        && request.resource.data.updatedAt == request.time
        && (
          (
            request.resource.data.status == "no_show"
            && request.resource.data.noShowActor in ["learner", "teacher"]
          )
          || (
            request.resource.data.status != "no_show"
            && (
              !("noShowActor" in request.resource.data)
              || (
                ("noShowActor" in resource.data)
                && request.resource.data.noShowActor == resource.data.noShowActor
              )
            )
          )
        )
        && (
          (
            request.auth.uid == resource.data.teacherId
            && (
              (
                resource.data.status == "pending"
                && request.resource.data.status in ["accepted", "rejected"]
              )
              || (
                resource.data.status == "accepted"
                && request.resource.data.status == "cancelled"
                && request.resource.data.cancelledBy == "teacher"
                && request.resource.data.cancellationReason is string
                && request.resource.data.cancellationReason.size() > 0
              )
              || (
                resource.data.status == "in_progress"
                && request.resource.data.status == "no_show"
              )
            )
          )
          || (
            bookingParticipant()
            && (
              (
                resource.data.status == "accepted"
                && request.resource.data.status == "in_progress"
              )
              || (
                resource.data.status == "in_progress"
                && request.resource.data.status == "completed"
              )
            )
          )
          || (
            request.auth.uid == resource.data.learnerId
            && resource.data.status == "pending"
            && request.resource.data.status == "cancelled"
          )
        )
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /lesson_offers/{offerId} {
      allow read: if true;
      allow create: if (
          isSignedIn()
          && canTeach(request.auth.uid)
          && request.resource.data.teacherId == request.auth.uid
        ) || isAdmin();
      allow update, delete: if (
          isSignedIn()
          && resource.data.teacherId == request.auth.uid
          && canTeach(request.auth.uid)
        ) || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if (
          isSignedIn()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.teacherId is string
        && request.resource.data.bookingId is string
        && exists(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId))
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.learnerId == request.auth.uid
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.teacherId == request.resource.data.teacherId
        && get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == "completed"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
      ) || isAdmin();

      allow update, delete: if (
          isSignedIn()
          && resource.data.reviewerId == request.auth.uid
        ) || isAdmin();
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /wallet_transactions/{txId} {
      allow read: if (
          isSignedIn()
          && resource.data.uid == request.auth.uid
        ) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /wallet_withdrawal_requests/{requestId} {
      allow read: if (
          isSignedIn()
          && resource.data.uid == request.auth.uid
        ) || isAdmin();

      allow create: if (
          isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.status == "pending"
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
          && exists(/databases/$(database)/documents/wallets/$(request.auth.uid))
          && get(/databases/$(database)/documents/wallets/$(request.auth.uid)).data.kycStatus == "verified"
          && request.resource.data.amount >= get(/databases/$(database)/documents/wallets/$(request.auth.uid)).data.withdrawalThreshold
          && request.resource.data.amount <= get(/databases/$(database)/documents/wallets/$(request.auth.uid)).data.availableBalance
        ) || isAdmin();

      allow update, delete: if isAdmin();
    }

    match /group_lessons/{lessonId} {
      allow read: if true;

      allow create: if (
          isSignedIn()
          && canTeach(request.auth.uid)
          && request.resource.data.lessonId == lessonId
          && request.resource.data.teacherId == request.auth.uid
          && request.resource.data.teacherDocId is string
          && exists(/databases/$(database)/documents/teachers/$(request.resource.data.teacherDocId))
          && get(/databases/$(database)/documents/teachers/$(request.resource.data.teacherDocId)).data.uid == request.auth.uid
          && request.resource.data.status == "scheduled"
          && request.resource.data.enrolledCount == 0
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
        ) || isAdmin();

      allow update: if (
          isSignedIn()
          && resource.data.teacherId == request.auth.uid
          && canTeach(request.auth.uid)
          && request.resource.data.lessonId == resource.data.lessonId
          && request.resource.data.teacherId == resource.data.teacherId
          && request.resource.data.teacherDocId == resource.data.teacherDocId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.enrolledCount == resource.data.enrolledCount
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "title",
            "description",
            "language",
            "level",
            "capacity",
            "pricePerSeat",
            "status",
            "scheduledAt",
            "durationMinutes",
            "updatedAt"
          ])
          && request.resource.data.updatedAt == request.time
          && (
            request.resource.data.status == resource.data.status
            || (
              resource.data.status == "scheduled"
              && request.resource.data.status in ["in_progress", "cancelled"]
            )
            || (
              resource.data.status == "in_progress"
              && request.resource.data.status == "completed"
            )
          )
        ) || isAdmin();

      allow delete: if (
          isSignedIn()
          && resource.data.teacherId == request.auth.uid
          && resource.data.status == "scheduled"
        ) || isAdmin();
    }

    match /group_enrollments/{enrollmentId} {
      allow read: if (
          isSignedIn()
          && (
            resource.data.learnerId == request.auth.uid
            || isGroupLessonTeacher(resource.data.lessonId)
          )
        ) || isAdmin();

      allow create: if (
          isSignedIn()
          && request.resource.data.enrollmentId == enrollmentId
          && request.resource.data.learnerId == request.auth.uid
          && enrollmentId == (request.resource.data.lessonId + "_" + request.auth.uid)
          && groupLessonExists(request.resource.data.lessonId)
          && groupLessonDoc(request.resource.data.lessonId).data.status == "scheduled"
          && request.resource.data.status == "enrolled"
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
        ) || isAdmin();

      allow update: if (
          isSignedIn()
          && request.resource.data.lessonId == resource.data.lessonId
          && request.resource.data.learnerId == resource.data.learnerId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"])
          && request.resource.data.updatedAt == request.time
          && (
            (
              request.auth.uid == resource.data.learnerId
              && resource.data.status == "enrolled"
              && request.resource.data.status == "cancelled"
            )
            || (
              isGroupLessonTeacher(resource.data.lessonId)
              && resource.data.status == "enrolled"
              && request.resource.data.status in ["attended", "no_show"]
            )
          )
        ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /service_learning_hours/{recordId} {
      allow read: if (
          isSignedIn()
          && resource.data.teacherId == request.auth.uid
        ) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /certificates/{certificateId} {
      allow read: if (
          isSignedIn()
          && resource.data.uid == request.auth.uid
        ) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /no_show_events/{eventId} {
      allow read: if (
          isSignedIn()
          && (
            resource.data.teacherId == request.auth.uid
            || resource.data.learnerId == request.auth.uid
          )
        ) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /teacher_quality_events/{eventId} {
      allow read: if (
          isSignedIn()
          && resource.data.teacherId == request.auth.uid
        ) || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
